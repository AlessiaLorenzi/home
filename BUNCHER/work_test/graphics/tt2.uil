object fileSelectionBox : XmFileSelectionDialog widget {
    arguments {
        XmNdirSpec = compound_string("/usr/users/andrea/iperbuncher/pa" &
 "rameters/");
        XmNapplyLabelString = compound_string("");
        XmNmustMatch = false;
        XmNminimizeButtons = false;
        XmNchildPlacement = XmPLACE_BELOW_SELECTION;
        XmNdirMask = compound_string("/usr/users/andrea/iperbuncher/pa" &
 "rameters/*");
        XmNx = 1;
        XmNy = 119;
        XmNwidth = 276;
        XmNheight = 427;
    };
    controls {
        Xm_Help unmanaged {
        };
        Xm_Apply unmanaged {
            arguments {
                arguments BaseStyle1;
            };
            callbacks {
                    callbacks BaseStyle1Reasons;
            };
!(BX)            handlers {
!(BX)                handlers BaseStyle1Handlers;
!(BX)            };
        };
    };
    callbacks {
        MrmNcreateCallback = procedure BxGlobalWidgetId(BXG_fileSelectionBox);
       XmNokCallback = procedures {
                 ok_cbk();
                 BxUnmanageCB("fileSelectionBox");
        };
        XmNcancelCallback = procedure BxUnmanageCB("fileSelectionBox");
    };
};

